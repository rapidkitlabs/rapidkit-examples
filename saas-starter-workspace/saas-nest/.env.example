NODE_ENV=development
PORT=8002
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_nest
REDIS_URL=redis://localhost:6379/0

# RapidKit Core module settings are injected below this stable anchor.
# <<<inject:module-env>>>
# <<<inject:module-env:rate_limiting_env:start>>>
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND="memory"
RATE_LIMIT_REDIS_URL="redis://localhost:6379/0"
RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_WINDOW=60
RATE_LIMIT_TRUST_FORWARDED_FOR=false
RATE_LIMIT_IDENTITY_HEADER="X-RateLimit-Identity"
# RATE_LIMIT_RULES_JSON can contain an optional JSON payload with extra rules.
RATE_LIMIT_RULES_JSON=""
# <<<inject:module-env:rate_limiting_env:end>>>
# <<<inject:module-env:redis_env:start>>>
# Redis module environment variables
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USE_TLS=false
CACHE_TTL=3600
REDIS_PRECONNECT=false
REDIS_CONNECT_RETRIES=3
REDIS_CONNECT_BACKOFF_BASE=0.5
# <<<inject:module-env:redis_env:end>>>
# <<<inject:module-env:users_core_env:start>>>


# Users Core module
# Controls baseline behaviour for user registration and directory endpoints.

# Feature toggles
RAPIDKIT_USERS_CORE_ALLOW_REGISTRATION=true
RAPIDKIT_USERS_CORE_ENFORCE_UNIQUE_EMAIL=true
RAPIDKIT_USERS_CORE_AUDIT_LOG_ENABLED=true
RAPIDKIT_USERS_CORE_PASSWORDLESS_SUPPORTED=false

# Defaults & limits
RAPIDKIT_USERS_CORE_DEFAULT_LOCALE=en
RAPIDKIT_USERS_CORE_MAX_RESULTS_PER_PAGE=100

# Comma-separated locale list (e.g. "en,fa,de")
RAPIDKIT_USERS_CORE_SUPPORTED_LOCALES=en

# <<<inject:module-env:users_core_env:end>>>
# <<<inject:module-env:db_postgres_env_defaults:start>>>
# PostgreSQL module environment defaults
RAPIDKIT_DB_POSTGRES_URL=${RAPIDKIT_DB_POSTGRES_URL:-postgresql://postgres:postgres@localhost:5432/app_db}
RAPIDKIT_DB_POSTGRES_TEST_URL=${RAPIDKIT_DB_POSTGRES_TEST_URL:-postgresql://postgres:postgres@localhost:5433/app_db_test}
RAPIDKIT_DB_POSTGRES_POOL_SIZE=${RAPIDKIT_DB_POSTGRES_POOL_SIZE:-10}
RAPIDKIT_DB_POSTGRES_MAX_OVERFLOW=${RAPIDKIT_DB_POSTGRES_MAX_OVERFLOW:-20}
RAPIDKIT_DB_POSTGRES_POOL_TIMEOUT=${RAPIDKIT_DB_POSTGRES_POOL_TIMEOUT:-30}
RAPIDKIT_DB_POSTGRES_POOL_RECYCLE=${RAPIDKIT_DB_POSTGRES_POOL_RECYCLE:-3600}
RAPIDKIT_DB_POSTGRES_ECHO=${RAPIDKIT_DB_POSTGRES_ECHO:-false}
# <<<inject:module-env:db_postgres_env_defaults:end>>>
# <<<inject:module-env:security_headers_env:start>>>

# Security Headers (NestJS)
SECURITY_HEADERS_ENABLED=true

# Strict-Transport-Security
SECURITY_HEADERS_STRICT_TRANSPORT_SECURITY=true
SECURITY_HEADERS_STRICT_TRANSPORT_SECURITY_MAX_AGE=63072000
SECURITY_HEADERS_STRICT_TRANSPORT_SECURITY_INCLUDE_SUBDOMAINS=true
SECURITY_HEADERS_STRICT_TRANSPORT_SECURITY_PRELOAD=true

# Content-Security-Policy (optional)
# SECURITY_HEADERS_CONTENT_SECURITY_POLICY="default-src 'self'; img-src 'self' data:; object-src 'none'"
SECURITY_HEADERS_CONTENT_SECURITY_POLICY_REPORT_ONLY=false

# Other common headers
SECURITY_HEADERS_REFERRER_POLICY="strict-origin-when-cross-origin"
SECURITY_HEADERS_X_CONTENT_TYPE_OPTIONS="nosniff"
SECURITY_HEADERS_X_FRAME_OPTIONS="DENY"
SECURITY_HEADERS_X_XSS_PROTECTION=false

# Cross-Origin policies (optional)
# SECURITY_HEADERS_CROSS_ORIGIN_EMBEDDER_POLICY="require-corp"
# SECURITY_HEADERS_CROSS_ORIGIN_OPENER_POLICY="same-origin"
# SECURITY_HEADERS_CROSS_ORIGIN_RESOURCE_POLICY="same-origin"

# Advanced (JSON strings; optional)
# SECURITY_HEADERS_PERMISSIONS_POLICY='{"geolocation": [], "camera": []}'
# SECURITY_HEADERS_ADDITIONAL_HEADERS='{"X-RapidKit-Example": "1"}'

# Optional / less common
# SECURITY_HEADERS_EXPECT_CT="max-age=86400, enforce"
SECURITY_HEADERS_X_DNS_PREFETCH_CONTROL="off"
SECURITY_HEADERS_X_DOWNLOAD_OPTIONS="noopen"
# <<<inject:module-env:security_headers_env:end>>>
# <<<inject:module-env:oauth_env:start>>>
# OAuth Module Environment Variables
OAUTH_REDIRECT_BASE_URL=https://example.com/auth/oauth
OAUTH_STATE_TTL_SECONDS=900
OAUTH_STATE_CLEANUP_INTERVAL=300
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
# <<<inject:module-env:oauth_env:end>>>
# <<<inject:module-env:auth_core_env:start>>>
# Auth Core signing pepper (generate with: openssl rand -base64 48)
RAPIDKIT_AUTH_CORE_PEPPER="please-set-a-long-random-secret"
# <<<inject:module-env:auth_core_env:end>>>
# <<<inject:module-env:logging_env:start>>>
# Logging Module Environment Variables
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_SINKS=["stderr"]  # JSON list form (preferred). You can also set comma list via settings (e.g., ["stderr","file"]).
LOG_FILE_PATH=logs/app.log
LOG_ASYNC_QUEUE=true
LOG_SAMPLING_RATE=1
LOG_ENABLE_REDACTION=true
OTEL_BRIDGE_ENABLED=false
METRICS_BRIDGE_ENABLED=false
RAPIDKIT_LOGGING_REQUEST_CONTEXT=true
LOGGING_HEALTHCHECK_ENABLED=true
LOGGING_HEALTHCHECK_PATH=/api/health/module/logging
# <<<inject:module-env:logging_env:end>>>
